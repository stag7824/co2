---
import '@fontsource/playfair-display/400.css';
import '@fontsource/playfair-display/600.css';
import '@fontsource/playfair-display/700.css';
import '@fontsource/playfair-display/400-italic.css';
import '@fontsource/dm-sans/300.css';
import '@fontsource/dm-sans/400.css';
import '@fontsource/dm-sans/500.css';
import '@fontsource/dm-sans/600.css';
import '@fontsource/dm-mono/400.css';
import '@fontsource/dm-mono/500.css';
import '../styles/global.css';

import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE } from '../config';
import { defaultLang, t, type Lang } from '../i18n/index';

interface Props {
  title: string;
  description?: string;
  lang?: Lang;
  alternateUrls?: { de?: string; en?: string };
  /** 'home' shows full anchor nav + Discord CTA; 'simple' shows brand+lang only. */
  headerVariant?: 'home' | 'simple';
}

const {
  title,
  description,
  lang = defaultLang,
  alternateUrls,
  headerVariant = 'home',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, SITE.url).toString();
const fallbackDescription = SITE.defaultDescription[lang];
const meta = description ?? fallbackDescription;
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} — {SITE.name}</title>
    <meta name="description" content={meta} />
    <link rel="canonical" href={canonical} />
    {alternateUrls?.de && (
      <link rel="alternate" hreflang="de" href={new URL(alternateUrls.de, SITE.url).toString()} />
    )}
    {alternateUrls?.en && (
      <link rel="alternate" hreflang="en" href={new URL(alternateUrls.en, SITE.url).toString()} />
    )}
    <meta property="og:title" content={`${title} — ${SITE.name}`} />
    <meta property="og:description" content={meta} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary" />
    <meta name="theme-color" content="#0c1a10" />
    <meta name="color-scheme" content="dark" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  </head>
  <body>
    <a href="#main" class="skip-link">{t(lang, 'nav.skipToContent')}</a>
    <Header lang={lang} alternateUrls={alternateUrls} variant={headerVariant} />
    <main id="main">
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
