---
import { t, type Lang } from '../../i18n/index';
import { DISCORD_INVITE } from '../../config';
import data from '../../data/social-platforms.json';

interface Props { lang: Lang; }
const { lang } = Astro.props;

type Sub = { labelKey: string; href: string };
const subLinks = data.discordSubLinks as Sub[];
const inviteHref = data.discordInvite ?? DISCORD_INVITE;

const features = [
  { icon: '📅', key: 'discord.feat.daily' },
  { icon: '🌍', key: 'discord.feat.languages' },
  { icon: '🔬', key: 'discord.feat.science' },
  { icon: '⚡', key: 'discord.feat.action' },
  { icon: '🤝', key: 'discord.feat.network' },
];
---
<section class="discord-section" id="discord">
  <div class="container">
    <div class="discord-card reveal">
      <span class="discord-icon">🌐</span>
      <h2 class="discord-title">
        {t(lang, 'discord.title1')} <em>{t(lang, 'discord.titleEm')}</em>
      </h2>
      <p class="discord-desc">{t(lang, 'discord.desc')}</p>

      <div class="discord-features">
        {features.map((f) => (
          <div class="discord-feat">
            <div class="discord-feat-icon">{f.icon}</div>
            <div class="discord-feat-label">{t(lang, f.key)}</div>
          </div>
        ))}
      </div>

      <a href={inviteHref} target="_blank" rel="noopener noreferrer" class="btn-discord">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057c.003.027.012.053.027.073a19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/>
        </svg>
        {t(lang, 'discord.cta')}
      </a>

      <div class="discord-sublinks">
        {subLinks.map((s) => (
          <a href={s.href} class="discord-sublink" target="_blank" rel="noopener noreferrer">
            {t(lang, s.labelKey)}
          </a>
        ))}
      </div>
    </div>
  </div>
</section>
