---
import BaseLayout from '../layouts/BaseLayout.astro';
import HomePage from '../components/HomePage.astro';
import { t } from '../i18n/index';
const lang = 'de';
const alt = { de: '/', en: '/en/' };
---
<BaseLayout
  lang={lang}
  title={t(lang, 'site.title')}
  description={t(lang, 'site.description')}
  alternateUrls={alt}
>
  <HomePage lang={lang} />
</BaseLayout>
